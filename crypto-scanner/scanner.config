# =============================================================================
# Scanner stack configuration  (scanner.config)
# =============================================================================
# The dedicated tuning file for the scanners — separate from .env, which holds only
# the cTrader credentials. Every setting below is commented out and shows its code
# default; UNCOMMENT and edit a line to change it. No secrets here, so this file is
# version-controlled (tuning history is tracked). Loaded by core/config.py.
#
# Resolution order (highest priority first):
#   1. shell env var   (e.g. pm2 env, or `FOO=1 python3 scanner.py`)
#   2. scanner.config  (this file)
#   3. code default    (the value shown after each key below = today's behaviour)
# Leave a key commented and the code default applies, so this file as-shipped changes
# nothing. (Override the file location with the SCANNER_CONFIG env var if needed.)
#
# PER-SCANNER OVERRIDES ------------------------------------------------------
# Each scanner process sets SCANNER_ROLE in ecosystem.config.js:
#   signal-scanner -> crypto,  metals-scanner -> metals,  xau-scanner -> xau
# A lookup for KEY tries "<ROLE>_KEY" first, then bare "KEY", then the default.
# So:
#   VOL_SPIKE_VETO_ATR=3.5          # applies to ALL scanners
#   CRYPTO_VOL_SPIKE_VETO_ATR=3.0   # crypto scanner only (overrides the above)
#   METALS_VOL_SPIKE_VETO_ATR=4.0   # metals scanner only
# Prefixes: CRYPTO_ / METALS_ / XAU_.  (SCANNER_ROLE itself is set by pm2, not here.)
#
# BARE-KEY COLLISIONS: a few names exist in more than one scanner — RSI_PERIOD,
# LOOKBACK, TIMEFRAME, LOOP, ACCOUNT_SIZE, RISK, MAX_POSITIONS. A BARE key affects
# every process that reads it; use the role prefix to tune them independently
# (e.g. XAU_RSI_PERIOD is xau's momentum RSI, CRYPTO_RSI_PERIOD is the crypto TF RSI).
# =============================================================================


# =========================== A. Bot / execution =============================
# scanner.py + metals-scanner.py. (CLI flags still win; pm2 passes -tf/--loop.)
#ACCOUNT_SIZE=10000       # USD account size (position sizing)
#RISK=0.02                # risk per trade (0.02 = 2%)
#MAX_POSITIONS=3          # max concurrent positions
#TIMEFRAME=1h             # scan timeframe (xau default is 15m -> use XAU_TIMEFRAME)
#LOOP=0                   # repeat every N minutes (0 = single run; pm2 sets 15/5)


# ===================== B. Anti-breakout guards (core/guards.py) =============
# Shared by scanner + metals. The "July-4 hardening" thresholds.
#RSI_CONTINUATION_PENALTY_START=75.0   # begin penalising a fade past this RSI extremity
#RSI_CONTINUATION_VETO=82.0            # veto the fade at/above this extremity
#RSI_CONTINUATION_PENALTY_PER_PT=6.0   # conf points removed per extremity point
#FADE_IMPULSE_BARS=2                   # bars of recent adverse impulse to measure
#FADE_IMPULSE_ATR_WINDOW=14            # ATR baseline window (bars)
#FADE_IMPULSE_PENALTY_ATR=0.6          # start penalising once adverse move > this (ATRs)
#FADE_IMPULSE_VETO_ATR=1.0             # veto once adverse move reaches this (ATRs)
#FADE_IMPULSE_PENALTY_PER_ATR=40.0     # conf points removed per ATR over the start
#NO_REARM_WINDOW_MIN=120               # only compare against same-symbol alerts this recent
#NO_REARM_ADVERSE_PCT=0.5              # skip re-arm if entry is this % worse than last
#VOL_SPIKE_PENALTY_ATR=2.0             # penalise once the last bar's range > this x ATR
#VOL_SPIKE_VETO_ATR=3.5                # veto once the last bar's range reaches this x ATR
#VOL_SPIKE_PENALTY_PER_ATR=18.0        # conf points removed per ATR over the start


# ====================== C. Strategy levels (core/strategy.py) ===============
#TP1_TIGHTEN_FACTOR=0.5      # pull TP1 toward entry (1.0 = original, 0.5 = halfway)
#USE_ATR_LEVELS=true         # ATR-scaled stops/targets (false = legacy %-levels)
#ATR_LEVEL_WINDOW=14         # ATR window (bars) for placing stop/TP
#ATR_STOP_MULT=1.5           # stop distance in ATRs
#ATR_TP1_MULT=1.0            # TP1 distance in ATRs (the feed's executed target)
#ATR_TP2_MULT=2.0            # scale-out target
#ATR_TP3_MULT=3.0            # scale-out target
#ATR_STOP_MIN_FRAC_OF_PCT=0.5  # clamp ATR stop >= this x the legacy %-stop
#ATR_STOP_MAX_FRAC_OF_PCT=2.0  # clamp ATR stop <= this x the legacy %-stop


# ===================== D. BTC regime engine (scanner.py, crypto) ============
#DOMINANCE_BASKET=ETH/USDT,SOL/USDT,XRP/USDT,BNB/USDT,ADA/USDT,DOGE/USDT,AVAX/USDT
#BTC_PRICE_THRESHOLD=0.5         # % move to call BTC bullish/bearish (else neutral)
#BTC_DOMINANCE_THRESHOLD=0.3     # BTC-minus-basket %; above -> RISING, below -> FALLING
#REGIME_HARD_FILTER_MIN_CONF=70  # a signal fighting the regime needs >= this conf
# BTC volatility circuit breaker:
#BTC_VOLATILITY_SHORT_WINDOW=10  # bars for "recent" volatility
#BTC_VOLATILITY_LONG_WINDOW=40   # bars for the baseline
#BTC_VOLATILITY_RATIO=2.0        # recent/baseline stdev above this -> EXPLOSIVE
#BTC_VOLATILITY_MIN_CONF=85      # soft mode: counter-trend needs >= this to survive
# --- TEMP 2026-07-07: circuit breaker relaxed to SOFT mode (was hard-pause).
# --- Counter-trend now survives explosive BTC if confidence >= BTC_VOLATILITY_MIN_CONF (85).
# --- Re-enable the July-4 hard-pause by restoring this to true (or re-commenting the line).
BTC_VOLATILITY_HARD_PAUSE=false  # was: true = pause ALL counter-trend when explosive
#BTC_VOLATILITY_FAST_BAR_ATR=2.5 # a single BTC bar this many ATRs wide trips the breaker
# Regime confidence matrix (points added to BUY/SELL per composite state; per-cell):
BTC_D_RISING_BULLISH_BUY=-35
#BTC_D_RISING_BULLISH_SELL=15
#BTC_D_RISING_BEARISH_BUY=-40
#BTC_D_RISING_BEARISH_SELL=20
#BTC_D_RISING_NEUTRAL_BUY=-25
#BTC_D_RISING_NEUTRAL_SELL=10
#BTC_D_FALLING_BULLISH_BUY=20
#BTC_D_FALLING_BULLISH_SELL=-25
#BTC_D_FALLING_BEARISH_BUY=-5
#BTC_D_FALLING_BEARISH_SELL=10
#BTC_D_FALLING_NEUTRAL_BUY=10
#BTC_D_FALLING_NEUTRAL_SELL=-10
#BTC_D_FLAT_BULLISH_BUY=10
#BTC_D_FLAT_BULLISH_SELL=-10
#BTC_D_FLAT_BEARISH_BUY=-15
#BTC_D_FLAT_BEARISH_SELL=10
#BTC_D_FLAT_NEUTRAL_BUY=0
#BTC_D_FLAT_NEUTRAL_SELL=0


# =============== E. Signal weights + weight % (core/strategy.py) ============
# Each filter's confidence delta is scaled by (W_<FILTER>_PCT/100) x (SIGNAL_WEIGHT_PCT/100).
# 100 = today's behaviour. e.g. CRYPTO_W_STRUCTURE_PCT=150 -> SMC structure matters 50% more.
#SIGNAL_WEIGHT_PCT=100      # GLOBAL scale on every filter delta
#W_VOLUME_PCT=100           # volume confirmation / divergence
#W_MA_PCT=100               # MA trend alignment
#W_HTF_PCT=100              # higher-timeframe RSI confirmation
#W_DIVERGENCE_PCT=100       # RSI/price divergence
#W_VELOCITY_PCT=100         # price-velocity (blow-off) penalty
#W_HTF_OVERRULE_PCT=100     # 1h RSI overrule of counter signals
#W_SQUEEZE_PCT=100          # squeeze-momentum release
#W_SMRE_PCT=100             # SMRE (z-score / Hurst / vol-regime)
#W_STRUCTURE_PCT=100        # SMC market structure (BOS/CHoCH)
#W_OB_PCT=100               # SMC order block
#W_FVG_PCT=100              # SMC fair-value gap


# ============ F. Timeframe shape knobs (scanner + metals, active TF) ========
# Override the resolved params for whatever timeframe the scanner runs (default = the
# TF matrix value; shown here for the live 1h). Use role prefixes to tune per-scanner.
#BANDWIDTH=6.0              # NW envelope smoothing bandwidth
#MULTIPLIER=3.0             # NW band distance multiplier
#RSI_PERIOD=14              # RSI period (NOTE: collides with xau's momentum RSI; prefix it)
#MA_PERIOD=200              # MA trend period
#CONFIRMATION_TIMEFRAME=4h  # higher timeframe used for RSI confirmation
#STOP_DISTANCE=0.025        # legacy %-stop (also clamps ATR stop)
#TARGET_1_PCT=0.03          # TP1 %
#TARGET_2_PCT=0.05          # TP2 %
#TARGET_3_PCT=0.07          # TP3 %
#LOOKBACK=500               # bars fetched (NOTE: collides with xau LOOKBACK; prefix it)


# ================== G. XAU momentum scanner (xau-scanner.py) ================
# Prefix with XAU_ to be unambiguous (several names collide with the crypto keys above).
#XAU_STOP_LOSS_PIPS=1000    # SL distance in pips (gold pip = 0.01)
#XAU_TAKE_PROFIT_PIPS=758   # TP distance in pips
#XAU_PIP=0.01               # pip size (gold quotes to 2 decimals)
#XAU_SIGNAL_CONFIDENCE=70.0 # fixed confidence for the (binary) momentum signal
#XAU_LOOKBACK=300           # bars fetched for indicator warmup
#XAU_AO_FAST=5              # Awesome Oscillator fast
#XAU_AO_SLOW=34             # Awesome Oscillator slow
#XAU_AO_LEVEL=1.0           # AO cross level (+/-)
#XAU_BEARS_PERIOD=43        # Bears Power period
#XAU_BEARS_LEVEL=0.0        # Bears Power level
#XAU_MACD_FAST=16
#XAU_MACD_SLOW=30
#XAU_MACD_SIGNAL=9
#XAU_CCI_PERIOD=27          # CCI close filter period
#XAU_CCI_LEVEL=599.0        # CCI close filter level
#XAU_RSI_PERIOD=10          # RSI close filter period
#XAU_RSI_LEVEL=2.0          # RSI close filter level (2 -> 2/98)
