# DoochyBot local agent configuration. The easiest way to fill this in is the
# wizard (pnpm doochybot:setup), which asks for the four credential values and
# finds your account id automatically. This file documents the fields for
# manual setup.
#
# You need your OWN cTrader account and your OWN Open API app; never share one
# account or an IP with another DoochyBot user (the broker forbids it).

# Demo accounts use the demo host; funded/live use live.ctraderapi.com.
# Wrong host gives CANT_ROUTE_REQUEST on account auth.
CTRADER_HOST=demo.ctraderapi.com
CTRADER_PORT=5035

# Your own Open API application: create it at https://openapi.ctrader.com/apps
# ("Add new app"), then press "Credentials" next to it and copy these two.
CLIENT_ID=
CLIENT_SECRET=

# Tokens generated on that same Credentials page for your cTrader ID, with
# access to your trading account approved.
ACCESS_TOKEN=
REFRESH_TOKEN=

# INTERNAL account id (ctidTraderAccountId), not the account number you see in
# the cTrader app. The wizard finds it for you; manually: fill in the four
# values above, then run "node scripts/lookup-account-id.js".
ACCOUNT_ID=

# The hub.
HUB_WS_URL=wss://doochy.route07.com/ws

# First run only: pairing code from sending /pair to @DoochyBot in Telegram.
# Normally not needed; the first interactive start asks for it.
# AGENT_PAIR_CODE=
