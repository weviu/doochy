{
  "name": "doochybot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && pnpm -r build",
    "build:webapp": "pnpm --filter doochybot-webapp build",
    "start": "node dist/index.js",
    "hub:dev": "tsx src/hub/index.ts",
    "hub:start": "node dist/hub/index.js",
    "doochybot:setup": "tsx scripts/setup.ts",
    "doochybot:start": "tsc && node dist/doochybot/index.js",
    "go": "pnpm install && pnpm doochybot:setup",
    "agent:dummy": "tsx scripts/dummy-agent.ts",
    "lookup": "node scripts/lookup-account-id.js",
    "update-creds": "tsx scripts/update-credentials.ts",
    "test:news": "tsx scripts/news-tests.ts",
    "test:timeexit": "tsx scripts/timeexit-tests.ts",
    "news:dryrun": "tsx scripts/news-dryrun.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.34.5",
  "dependencies": {
    "@reiryoku/ctrader-layer": "^2.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "grammy": "^1.43.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "pm2": "^7.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
