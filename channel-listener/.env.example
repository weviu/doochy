# Telegram API credentials (from https://my.telegram.org -> API development tools)
API_ID=your_api_id
API_HASH=your_api_hash

# Phone number of the Telegram user account (international format, e.g. +14155551234).
# This account must be a member of every channel below.
PHONE_NUMBER=+14155551234

# Channels to listen to. Configure up to 5 as CHANNEL_1 .. CHANNEL_5.
# USERNAME is a public @username or a private invite link (https://t.me/+...).
# PARSER is the message format: "sureshot" (multi-message) or "fxoro" (single).
# A channel with an empty USERNAME is ignored.
CHANNEL_1_USERNAME=https://t.me/ssfgold
CHANNEL_1_PARSER=sureshot

CHANNEL_2_USERNAME=https://t.me/fxoro_signals
CHANNEL_2_PARSER=fxoro

# DoochyBot webhook endpoint that receives the formatted signal as text/plain.
WEBHOOK_URL=http://localhost:9009/webhook
